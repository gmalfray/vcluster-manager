apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: argocd-{{.Name}}
  namespace: vcluster-{{.Name}}
spec:
  kubeConfig:
    secretRef:
      name: vc-vcluster-{{.Name}}-int
      key: config
  interval: 5m
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  path: ./clusters/{{.Env}}/vclusters/{{.Name}}/tenant/argocd
  prune: true
  timeout: 5m
  postBuild:
    substituteFrom:
      - kind: ConfigMap
        name: cluster-vars
    substitute:
      VAULT_KUBERNETES_AUTH_PATH: "kubernetes-vcluster-{{.Name}}-{{.Env}}"
