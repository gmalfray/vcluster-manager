# Copier ce fichier en .env pour le développement local.
# En production (K8s), ces valeurs sont dans deploy/base/config.env (ConfigMap)
# et les secrets dans vcluster-manager-secrets / vcluster-manager-auth.

# Server
LISTEN_ADDR=:8080
DATA_DIR=data

# Backend de persistence pour settings.json et deleting.json
# "file" (défaut) : fichiers locaux dans DATA_DIR (nécessite un PVC)
# "configmap"     : ConfigMap K8s "vcluster-manager-state" dans le namespace courant
#                   (survie au rescheduling sans PVC — nécessite STATE_BACKEND=configmap + RBAC Role)
STATE_BACKEND=file
# K8S_NAMESPACE=vcluster-manager  # namespace cible pour le backend configmap (défaut: lu depuis serviceaccount)

# GitLab
GITLAB_URL=https://gitlab.example.com
GITLAB_SSH_URL=ssh://git@gitlab.example.com:22
GITLAB_ARGOCD_PATH=ops/argocd
FLUXCD_DEPLOY_KEY_ID=0
GITLAB_TOKEN=                    # requis
GITLAB_PROJECT_ID=
GITLAB_ARGOCD_GROUP_ID=
GITLAB_HELM_PROJECT_ID=

# Keycloak
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# OIDC (auth utilisateurs)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=

# Auth locale (dev)
ADMIN_PASSWORD=
JWT_SECRET=

# Domains
BASE_DOMAIN_PREPROD=preprod.example.com
BASE_DOMAIN_PROD=example.com

# TLS secrets (wildcard secrets pre-existing in host clusters)
TLS_SECRET_PREPROD=wildcard-preprod-example-com-tls
TLS_SECRET_PROD=wildcard-example-com-tls

# vCluster defaults
DEFAULT_CPU=8
DEFAULT_MEMORY=32Gi
DEFAULT_STORAGE=500Gi
VELERO_TIMEZONE=Europe/Paris
VCLUSTER_POD_SECURITY=privileged
ARGOCD_DEFAULT_POLICY=role:readonly

# Cluster labels
CLUSTER_LABEL_PREPROD=Preprod
CLUSTER_LABEL_PROD=Prod

# Kubernetes (optionnel, sinon in-cluster)
KUBECONFIG_PREPROD=
KUBECONFIG_PROD=

# SSH tunnel (optionnel)
SSH_KEY_PATH=/root/.ssh/id_rsa
SSH_TUNNEL_PREPROD=
SSH_TUNNEL_PROD=

# Rancher (optionnel)
RANCHER_URL=
RANCHER_TOKEN=
RANCHER_ENABLED_PREPROD=false
RANCHER_ENABLED_PROD=false

# Vault (optionnel)
VAULT_ADDR=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_TOKEN=

# Notifications webhook (optionnel — Slack, Mattermost, Rocket.Chat, etc.)
# Format attendu : endpoint acceptant un POST JSON {"text": "..."}
# Exemple Slack : https://hooks.slack.com/services/XXX/YYY/ZZZ
WEBHOOK_URL=

# RBAC — groupe OIDC par défaut pour les nouveaux vclusters (défaut: "developers")
DEFAULT_RBAC_GROUP=developers

# Groupes OIDC admin (virgule-séparés, défaut: "platform-admins,ops")
ADMIN_GROUPS=platform-admins,ops

# Chemins dans le repo fluxprod (modifier si votre repo GitOps a une structure différente)
FLUXPROD_CLUSTERS_PATH=clusters
FLUXPROD_ARGOCD_KUST_PATH=lib/tenant-template/argocd/base/kustomization.yaml

# Chemin du chart vcluster dans platform-helm-charts (défaut: "charts/vcluster")
HELM_CHARTS_VCLUSTER_PATH=charts/vcluster

# Chemins Vault KV pour les credentials ArgoCD
VAULT_KV_ARGOCD_ROOTAPPS=secret/data/vcluster/argocd/rootapps
VAULT_KV_ARGOCD_REPO=secret/data/vcluster/argocd/repo
